---
import PlaceholderImage from "./PlaceholderImage.astro";
import { splitHighlighted } from "../utils/highlightText";
import type { PainPointsContent } from "../types/content";

interface Props {
  content: PainPointsContent;
}

const { content } = Astro.props;

const rotations = [-2, 1, -1.5, 2, -1, 1.5];
const accentColors = ["var(--color-red)", "var(--color-ocher)"];
const headingParts = splitHighlighted(content.heading, content.highlightWords);
---

<section id="pain-points" class="pain-points">
	<div class="container pain-points-inner">
		<div class="pain-points-copy">
			<h2>
				{headingParts.map((part, i) =>
					part.highlight ? (
						<span class="highlight" style={`--highlight-color: ${accentColors[i % accentColors.length]}`}>{part.text}</span>
					) : (
						<>{part.text}</>
					)
				)}
			</h2>
			<ul class="bubbles">
				{content.questions.map((question, i) => (
					<li
						class="bubble"
						data-hover-wiggle
						style={`--rotate: ${rotations[i % rotations.length]}deg`}
					>
						{question}
					</li>
				))}
			</ul>
			<a class="button button-primary" href={content.cta.target} data-hover-lift>{content.cta.label}</a>
		</div>
		<div class="pain-points-portrait" data-hover-lift>
			<PlaceholderImage
				src={content.image || undefined}
				alt="Photo of Lara"
				variant="portrait"
				frame
				rotate={2}
				tapeColor="var(--color-red)"
			/>
		</div>
	</div>
</section>

<style>
	.pain-points {
		padding: var(--section-padding);
	}

	.pain-points-inner {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: center;
	}

	.pain-points-copy {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	h2 {
		font-size: clamp(1.8rem, 3.5vw, 2.6rem);
		color: var(--color-teal-dark);
	}

	.highlight {
		color: var(--highlight-color);
	}

	.bubbles {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
	}

	.bubble {
		position: relative;
		background: var(--color-white);
		border: 2px solid var(--color-teal);
		color: var(--color-teal-dark);
		border-radius: var(--radius-lg);
		padding: 1rem 1.5rem;
		font-weight: 700;
		font-size: 1.05rem;
		box-shadow: var(--shadow-soft);
		transform: rotate(var(--rotate));
	}

	.bubble::after {
		content: "";
		position: absolute;
		bottom: -0.55rem;
		left: 1.6rem;
		width: 1rem;
		height: 1rem;
		background: var(--color-white);
		border-bottom: 2px solid var(--color-teal);
		border-right: 2px solid var(--color-teal);
		transform: rotate(45deg);
		border-radius: 0 0 3px 0;
	}

	.pain-points-portrait {
		width: min(190px, 50vw);
		margin-left: auto;
	}

	@media (max-width: 800px) {
		.pain-points-inner {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.pain-points-copy {
			align-items: center;
		}

		.bubbles {
			justify-content: center;
		}

		.pain-points-portrait {
			margin-inline: auto;
		}
	}
</style>
