---
import SpritzTitle from "./SpritzTitle.astro";
import type { SiteMeta } from "../types/content";

interface Props {
  meta: SiteMeta;
}

const { meta } = Astro.props;

const links = [
  { href: "#hero", label: "Home" },
  { href: "#about", label: "About" },
  { href: "#method", label: "Method" },
  { href: "#results", label: "Results" },
  { href: "#contact", label: "Contact" },
];
---

<header class="navbar">
	<nav class="navbar-inner container">
		<a href="#hero" class="brand" data-hover-lift>
				<SpritzTitle text={meta.siteName} image={meta.image} size="1.15em" gap="-0.05em" />
			</a>
		<ul class="nav-links">
			{links.map((link) => (
				<li>
					<a href={link.href} data-hover-lift>{link.label}</a>
				</li>
			))}
		</ul>
	</nav>
</header>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		background: rgb(11 91 84 / 0.92);
		backdrop-filter: blur(10px);
		box-shadow: 0 1px 0 rgb(255 255 255 / 0.08);
	}

	.navbar-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 0.9rem clamp(1.5rem, 6vw, 4rem);
	}

	.brand {
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1.15rem;
		color: var(--color-white);
		text-decoration: none;
		white-space: nowrap;
	}

	.nav-links {
		list-style: none;
		display: flex;
		flex: 1;
		min-width: 0;
		align-items: center;
		justify-content: flex-end;
		gap: clamp(1rem, 3vw, 1.75rem);
		margin: 0;
		padding: 0;
		overflow-x: auto;
	}

	.nav-links a {
		text-decoration: none;
		font-weight: 700;
		font-size: 0.92rem;
		color: var(--color-white);
		white-space: nowrap;
		transition: color 0.2s ease;
	}

	.nav-links a:hover {
		color: var(--color-yellow);
	}

	@media (max-width: 480px) {
		.navbar-inner {
			gap: 0.75rem;
			padding: 0.75rem 1rem;
		}

		.brand {
			font-size: 1rem;
		}

		.nav-links {
			justify-content: flex-start;
			gap: 0.85rem;
		}

		.nav-links a {
			font-size: 0.85rem;
		}
	}
</style>
