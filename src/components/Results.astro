---
import PlaceholderImage from "./PlaceholderImage.astro";
import SectionKicker from "./SectionKicker.astro";
import { renderMarkdown } from "../utils/markdown";
import type { ResultsContent } from "../types/content";

interface Props {
  content: ResultsContent;
}

const { content } = Astro.props;

const levels = [
  { key: "beginner", label: "Beginner" },
  { key: "intermediate", label: "Intermediate" },
  { key: "advanced", label: "Advanced" },
] as const;

const activeLevels = levels
  .filter((level) => Boolean(content[level.key]))
  .map((level) => ({ ...level, html: renderMarkdown(content[level.key]) }));
---

<section id="results" class="results">
	<svg class="results-blob" viewBox="0 0 400 400" aria-hidden="true">
		<path
			fill="var(--color-ocher)"
			d="M300 70 C360 130 350 250 280 310 C210 370 90 360 50 290 C10 220 30 100 110 60 C190 20 240 10 300 70 Z"
		/>
	</svg>
	<div class="container results-inner">
		<div class="results-image" data-hover-lift>
			<PlaceholderImage
				src={content.image || undefined}
				alt="Results of learning Italian with Lara"
				variant="rounded"
				frame
				rotate={-3}
				tapeColor="var(--color-lightblue)"
			/>
		</div>
		<div class="results-levels">
			<SectionKicker label="Results" color="var(--color-ocher)" />
			<h2>Results</h2>
			{activeLevels.map((level) => (
				<div class="results-card" data-hover-lift>
					<span class="results-label">{level.label}</span>
					<div set:html={level.html} />
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.results {
		position: relative;
		padding: var(--section-padding);
		overflow: hidden;
	}

	.results-blob {
		position: absolute;
		bottom: -15%;
		left: -10%;
		width: 28rem;
		height: 28rem;
		opacity: 0.1;
		pointer-events: none;
		z-index: 0;
	}

	.results-inner {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: 1fr 1.4fr;
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: start;
	}

	.results-image {
		aspect-ratio: 3 / 2;
	}

	h2 {
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		color: var(--color-teal-dark);
		margin-bottom: 1.5rem;
	}

	.results-levels {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.results-card {
		background: var(--color-white);
		border-left: 4px solid var(--color-ocher);
		border-radius: var(--radius-sm);
		padding: 1.25rem 1.5rem;
		box-shadow: var(--shadow-soft);
	}

	.results-label {
		display: inline-block;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-size: 0.75rem;
		font-weight: 700;
		color: var(--color-ocher);
		margin-bottom: 0.4rem;
	}

	.results-card :global(strong) {
		color: var(--color-teal-dark);
	}

	.results-card :global(p) {
		color: var(--color-ink-soft);
	}

	@media (max-width: 800px) {
		.results-inner {
			grid-template-columns: 1fr;
		}

		.results-image {
			max-width: 20rem;
			margin-inline: auto;
		}
	}
</style>
