---
import { withBase } from "../utils/baseUrl";
import type { CursorAssets } from "../types/content";

interface Props {
  cursor: CursorAssets;
}

const { cursor } = Astro.props;
---

<div class="cursor-mark cursor-spritz" aria-hidden="true">
	{cursor.spritzImage ? (
		<img src={withBase(cursor.spritzImage)} alt="" width="48" height="48" />
	) : (
		<span class="cursor-emoji">🍹</span>
	)}
</div>

<div class="cursor-mark cursor-ice" aria-hidden="true">
	{cursor.iceImage ? (
		<img src={withBase(cursor.iceImage)} alt="" width="48" height="48" />
	) : (
		<svg viewBox="0 0 24 24" width="48" height="48" fill="none">
			<path
				d="M6 5 L18 5 L20 18 L4 18 Z"
				fill="var(--color-lightblue)"
				fill-opacity="0.55"
				stroke="var(--color-white)"
				stroke-width="1.4"
				stroke-linejoin="round"
			/>
			<path d="M9 5 L8 18 M15 5 L16 18 M6 5 L18 5" stroke="var(--color-white)" stroke-width="1" stroke-opacity="0.7" />
		</svg>
	)}
</div>

<div class="cursor-mark cursor-orange" aria-hidden="true">
	{cursor.orangeSliceImage ? (
		<img src={withBase(cursor.orangeSliceImage)} alt="" width="48" height="48" />
	) : (
		<svg viewBox="0 0 24 24" width="48" height="48" fill="none">
			<circle cx="12" cy="12" r="10" fill="var(--color-yellow)" stroke="var(--color-ocher)" stroke-width="2" />
			<g stroke="var(--color-white)" stroke-width="1" stroke-linecap="round">
				<line x1="12" y1="12" x2="12" y2="3" />
				<line x1="12" y1="12" x2="19.8" y2="7.5" />
				<line x1="12" y1="12" x2="19.8" y2="16.5" />
				<line x1="12" y1="12" x2="12" y2="21" />
				<line x1="12" y1="12" x2="4.2" y2="16.5" />
				<line x1="12" y1="12" x2="4.2" y2="7.5" />
			</g>
		</svg>
	)}
</div>

<style>
	.cursor-mark {
		position: fixed;
		top: 0;
		left: 0;
		pointer-events: none;
		z-index: 9999;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: translate(-50%, -50%);
		opacity: 0;
		transition: opacity 0.2s ease, transform 0.2s ease;
	}

	.cursor-mark.is-active {
		transform: translate(-50%, -50%) scale(1.35);
	}

	.cursor-spritz {
		filter: drop-shadow(0 2px 4px rgb(0 0 0 / 0.25));
	}

	.cursor-emoji {
		font-size: 2.8rem;
		line-height: 1;
	}

	.cursor-ice,
	.cursor-orange {
		width: 48px;
		height: 48px;
	}
</style>

<script>
	const isFinePointer = window.matchMedia("(pointer: fine)").matches;
	const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

	if (isFinePointer && !prefersReducedMotion) {
		document.body.classList.add("has-custom-cursor");

		const marks = [
			{ el: document.querySelector<HTMLElement>(".cursor-spritz")!, lag: 1, x: 0, y: 0 },
			{ el: document.querySelector<HTMLElement>(".cursor-ice")!, lag: 0.13, x: 0, y: 0 },
			{ el: document.querySelector<HTMLElement>(".cursor-orange")!, lag: 0.09, x: 0, y: 0 },
		];

		let targetX = 0;
		let targetY = 0;

		const show = () => {
			marks.forEach((mark) => (mark.el.style.opacity = "1"));
		};

		window.addEventListener(
			"pointermove",
			(event) => {
				show();
				targetX = event.clientX;
				targetY = event.clientY;
			},
			{ passive: true }
		);

		document.addEventListener("mouseleave", () => {
			marks.forEach((mark) => (mark.el.style.opacity = "0"));
		});

		const interactiveSelector = "a, button, [data-hover-lift], [data-cursor-grow]";

		document.addEventListener("mouseover", (event) => {
			if ((event.target as HTMLElement).closest(interactiveSelector)) {
				marks.forEach((mark) => mark.el.classList.add("is-active"));
			}
		});

		document.addEventListener("mouseout", (event) => {
			if ((event.target as HTMLElement).closest(interactiveSelector)) {
				marks.forEach((mark) => mark.el.classList.remove("is-active"));
			}
		});

		const animate = () => {
			marks.forEach((mark) => {
				mark.x += (targetX - mark.x) * mark.lag;
				mark.y += (targetY - mark.y) * mark.lag;
				mark.el.style.left = `${mark.x}px`;
				mark.el.style.top = `${mark.y}px`;
			});
			requestAnimationFrame(animate);
		};

		requestAnimationFrame(animate);
	}
</script>
