---
interface Props {
  label: string;
  color?: string;
}

const { label, color = "var(--color-ocher)" } = Astro.props;
---

<span class="section-kicker" style={`--kicker-color: ${color}`}>{label}</span>

<style>
	.section-kicker {
		display: inline-block;
		background: var(--kicker-color, var(--color-ocher));
		color: var(--color-ink);
		font-weight: 700;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.3rem 0.9rem;
		border-radius: 2px;
		transform: rotate(-2deg);
		margin-bottom: 1rem;
	}
</style>
