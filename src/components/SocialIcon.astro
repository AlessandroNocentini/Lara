---
interface Props {
  platform: string;
}

const { platform } = Astro.props;

const icons: Record<string, string> = {
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />',
  facebook:
    '<path d="M14 8h2V5h-2a3 3 0 0 0-3 3v2H9v3h2v6h3v-6h2.2l.8-3H14V8.5c0-.3.2-.5.5-.5z" fill="currentColor" stroke="none" />',
  whatsapp:
    '<path d="M12 3a8.5 8.5 0 0 0-7.3 12.8L3 21l5.4-1.6A8.5 8.5 0 1 0 12 3z" /><path d="M8.5 8.8c.2-.5.4-.5.7-.5h.5c.2 0 .4 0 .5.4.2.5.6 1.6.6 1.7.1.1.1.3 0 .4-.1.2-.2.3-.3.4l-.4.5c-.1.1-.2.3-.1.5.2.4.7 1.1 1.4 1.7.9.8 1.6 1 1.8 1.2.2.1.4.1.5-.1l.6-.7c.2-.2.4-.2.6-.1l1.5.7c.2.1.4.2.4.4 0 .6-.2 1.2-.6 1.6-.4.4-1 .7-1.6.7-1.5 0-3.1-.7-4.5-2-1.4-1.3-2.3-2.9-2.4-4.4 0-.6.2-1.2.6-1.6z" fill="currentColor" stroke="none" />',
  tiktok:
    '<path d="M14 4v9.2a2.3 2.3 0 1 1-2.3-2.3" /><path d="M14 4c.3 2 1.8 3.4 3.7 3.6" />',
  email:
    '<rect x="3" y="5" width="18" height="14" rx="2" /><path d="M4 7l8 6 8-6" />',
  website:
    '<circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />',
};

const label = platform.charAt(0).toUpperCase() + platform.slice(1);
const path = icons[platform.toLowerCase()] ?? icons.website;
---

<svg
  viewBox="0 0 24 24"
  width="20"
  height="20"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  role="img"
  aria-label={label}
  set:html={path}
/>
